<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Staggered entry animation delay calculation
        const children = document.querySelectorAll('.stagger-entry > *');
        children.forEach((child, index) => {
            child.style.animationDelay = `${index * 0.15}s`;
        });

        // Add micro-interaction glow to neo-cards
        const cards = document.querySelectorAll('.neo-card');
        cards.forEach(card => {
            card.addEventListener('mouseenter', () => {
                card.style.filter = 'drop-shadow(0 0 15px rgba(199, 240, 45, 0.3))';
            });
            card.addEventListener('mouseleave', () => {
                card.style.filter = 'none';
            });
        });
    });
</script>
