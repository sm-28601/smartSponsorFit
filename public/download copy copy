<script>
    function animateGauge(finalScore) {
        const circle = document.getElementById('gauge-circle');
        const text = document.getElementById('score-text');
        const circumference = 440; // 2 * PI * 70
        
        // Circular stroke draw
        const offset = circumference - (finalScore / 100) * circumference;
        circle.style.strokeDashoffset = offset;
        
        // Count animation
        let current = 0;
        const duration = 2000;
        const startTime = performance.now();
        
        function update(now) {
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / duration, 1);
            // Easing
            const easedProgress = 1 - Math.pow(1 - progress, 3);
            current = Math.floor(easedProgress * finalScore);
            text.textContent = current;
            
            if (progress < 1) {
                requestAnimationFrame(update);
            }
        }
        requestAnimationFrame(update);
    }

    // Initialize gauge on load
    window.addEventListener('load', () => {
        setTimeout(() => animateGauge(89), 500);
    });

    function simulateAnalysis() {
        const btn = event.currentTarget;
        const pipeline = document.getElementById('pipeline-section');
        const results = document.getElementById('results-section');
        
        btn.innerHTML = '<span class="material-symbols-outlined animate-spin font-black">sync</span> PROCESSING...';
        btn.classList.add('opacity-80', 'cursor-not-allowed');
        results.classList.add('opacity-30', 'blur-md', 'pointer-events-none');
        pipeline.classList.remove('hidden');
        pipeline.scrollIntoView({ behavior: 'smooth', block: 'center' });

        const stages = pipeline.querySelectorAll('.relative.z-10');
        let stageIndex = 0;

        const interval = setInterval(() => {
            if(stageIndex < stages.length) {
                stages[stageIndex].classList.remove('opacity-40');
                const icon = stages[stageIndex].querySelector('.w-14');
                icon.classList.add('bg-primary');
                stageIndex++;
            } else {
                clearInterval(interval);
                setTimeout(() => {
                    btn.innerHTML = '<span class="material-symbols-outlined font-black">analytics</span> RE-ANALYZE ALIGNMENT';
                    btn.classList.remove('opacity-80', 'cursor-not-allowed');
                    results.classList.remove('opacity-30', 'blur-md', 'pointer-events-none');
                    pipeline.classList.add('hidden');
                    results.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    animateGauge(89);
                }, 500);
            }
        }, 800);
    }

    function toggleDetails() {
        const content = document.getElementById('details-content');
        const chevron = document.getElementById('chevron');
        content.classList.toggle('hidden');
        chevron.style.transform = content.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';
    }

    document.getElementById('brand-tab').addEventListener('click', function() {
        this.className = "pb-4 text-black font-black border-b-4 border-black transition-all flex items-center gap-2 uppercase tracking-tight";
        document.getElementById('creator-tab').className = "pb-4 text-black/60 hover:text-black font-bold transition-all flex items-center gap-2 uppercase tracking-tight";
    });
    document.getElementById('creator-tab').addEventListener('click', function() {
        this.className = "pb-4 text-black font-black border-b-4 border-black transition-all flex items-center gap-2 uppercase tracking-tight";
        document.getElementById('brand-tab').className = "pb-4 text-black/60 hover:text-black font-bold transition-all flex items-center gap-2 uppercase tracking-tight";
    });
</script>
